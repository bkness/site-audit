{
  "name": "@bkness/site-audit",
  "version": "0.1.3",
  "description": "Fast, opinionated website audit — SEO, accessibility, performance, security, technical. Generates a beautiful, portable HTML report with plain-English impact for every finding.",
  "type": "module",
  "bin": {
    "site-audit": "dist/audit.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "audit",
    "seo",
    "accessibility",
    "a11y",
    "performance",
    "security",
    "website",
    "cli",
    "lighthouse-alternative",
    "html-report"
  ],
  "author": "Brandon Kelly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bkness/site-audit.git"
  },
  "homepage": "https://github.com/bkness/site-audit#readme",
  "bugs": {
    "url": "https://github.com/bkness/site-audit/issues"
  },
  "funding": [
    {
      "type": "individual",
      "url": "https://brandon-kelly.netlify.app"
    }
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "audit": "tsx src/audit.ts",
    "audit:strict": "tsx src/audit.ts --profile strict",
    "audit:enterprise": "tsx src/audit.ts --profile enterprise",
    "audit:clean": "tsx src/audit.ts --min-level warn",
    "audit:clean-strict": "tsx src/audit.ts --profile strict --min-level warn",
    "audit:clean-enterprise": "tsx src/audit.ts --profile enterprise --min-level warn",
    "audit:debug": "tsx src/audit.ts --show-confidence"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "cheerio": "^1.2.0"
  }
}
